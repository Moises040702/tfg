<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black">

    <TextureView
        android:id="@+id/videoViewRutina"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <ImageButton
        android:id="@+id/btnVolverVideo"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="#66000000"
        android:contentDescription="@string/volver_desc"
        android:padding="10dp"
        android:src="@android:drawable/ic_media_previous" />

    <ImageButton
        android:id="@+id/btnPlayPauseVideo"
        android:layout_width="76dp"
        android:layout_height="76dp"
        android:layout_gravity="center"
        android:background="#66000000"
        android:contentDescription="@string/pausar"
        android:padding="18dp"
        android:src="@android:drawable/ic_media_pause" />

    <LinearLayout
        android:id="@+id/layoutControlesVideo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#66000000"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="18dp">

        <SeekBar
            android:id="@+id/seekBarVideo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvTiempoVideo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:00 / 00:00"
            android:textColor="@android:color/white"
            android:textSize="13sp" />

        <Button
            android:id="@+id/btnRepetirVideo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/repetir_video"
            android:visibility="gone" />

    </LinearLayout>

</FrameLayout>