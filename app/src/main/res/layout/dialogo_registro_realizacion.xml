<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <EditText
            android:id="@+id/editFechaRealizacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fecha (yyyy-MM-dd)"
            android:focusable="false"
            android:clickable="true"
            android:inputType="none" />

        <EditText
            android:id="@+id/editHoraInicio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Hora inicio (HH:mm)"
            android:inputType="time" />

        <EditText
            android:id="@+id/editHoraFin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Hora fin (HH:mm)"
            android:inputType="time" />

        <EditText
            android:id="@+id/editSeriesObjetivoRegistro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Series objetivo"
            android:inputType="number" />

        <EditText
            android:id="@+id/editRepsObjetivoRegistro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Repeticiones objetivo"
            android:inputType="number" />

        <EditText
            android:id="@+id/editSeriesRealizadas"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/series_realizadas"
            android:inputType="number" />

        <EditText
            android:id="@+id/editRepsPorSerie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/repeticiones_por_serie"
            android:inputType="number" />

        <EditText
            android:id="@+id/editPesoUtilizado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="@string/peso_utilizado"
            android:inputType="numberDecimal" />

    </LinearLayout>
</ScrollView>